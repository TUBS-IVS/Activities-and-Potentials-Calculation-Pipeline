# ── Secrets ───────────────────────────────────────────────────────────────────
.env

# ── Large input / output data (region-specific, not for version control) ──────
data/input/*
!data/input/.gitkeep

data/output/*
!data/output/.gitkeep
!data/output/llm_predictions/
data/output/llm_predictions/*
!data/output/llm_predictions/.gitkeep

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.venv/
venv/
env/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Claude Code internal settings ─────────────────────────────────────────────
.claude/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
